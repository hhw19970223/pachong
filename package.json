{
  "name": "cron-spider-ts",
  "version": "1.0.0",
  "description": "一个基于 TypeScript 和 Express 的定时爬虫服务",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/index.ts",
    "debug": "node --inspect-brk -r ts-node/register -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo \"Linting not configured\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "start:prod": "npm run build && npm start"
  },
  "keywords": [
    "cron",
    "scheduler",
    "web-scraper",
    "typescript",
    "express",
    "spider",
    "automation"
  ],
  "author": "hhw",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
