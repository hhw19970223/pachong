# 服务端口
PORT=3000

# 数据库配置（可选）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cronservice
# DB_USER=postgres
# DB_PASS=password

# Webhook配置（可选）
# DEFAULT_WEBHOOK=https://your-webhook-url.com/notify

# 爬虫配置
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36
REQUEST_TIMEOUT=10000

# 日志级别
LOG_LEVEL=info